{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://allen.is/infereval/schema/evaluation-1.0.json",
  "title": "infereval evaluation (eta)",
  "$defs": {
    "EndorsementConfig": {
      "additionalProperties": false,
      "description": "Configuration governing how :math:`E_M` is computed.\n\nNote on terminology: ``n_samples`` is the number of *completions\ndrawn from M* per benchmark item, in the LLM-literature sense of\n\"sample\" (one draw from the model's output distribution). It is\n**not** the number of dataset rows \u2014 that is the benchmark's item\ncount and is fixed by the benchmark. The methodology issues\n``n_samples`` provider calls per item, parses each completion's\nverdict token, and majority-votes to compute :math:`E_M` for that\nitem. See ``docs/concepts.md`` for the full terminology note.",
      "properties": {
        "n_samples": {
          "default": 5,
          "title": "N Samples",
          "type": "integer"
        },
        "tie_break": {
          "default": "abstain",
          "enum": [
            "abstain",
            "good",
            "bad",
            "first"
          ],
          "title": "Tie Break",
          "type": "string"
        },
        "verification_prompt_id": {
          "default": "default-v1",
          "title": "Verification Prompt Id",
          "type": "string"
        },
        "context_builder_premise_id": {
          "default": "conjunction-and-v1",
          "title": "Context Builder Premise Id",
          "type": "string"
        },
        "context_builder_conclusion_id": {
          "default": "disjunction-or-v1",
          "title": "Context Builder Conclusion Id",
          "type": "string"
        }
      },
      "title": "EndorsementConfig",
      "type": "object"
    },
    "EvaluationItem": {
      "additionalProperties": false,
      "description": "One row of the evaluation :math:`\\eta`: implication + analyst verdicts + :math:`E_M`.",
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "premises": {
          "items": {
            "type": "string"
          },
          "title": "Premises",
          "type": "array"
        },
        "conclusions": {
          "items": {
            "type": "string"
          },
          "title": "Conclusions",
          "type": "array"
        },
        "analyst_verdicts": {
          "items": {
            "$ref": "#/$defs/Verdict"
          },
          "title": "Analyst Verdicts",
          "type": "array"
        },
        "model_verdict": {
          "$ref": "#/$defs/Verdict"
        },
        "samples": {
          "items": {
            "$ref": "#/$defs/SampleRecord"
          },
          "title": "Samples",
          "type": "array"
        },
        "majority_vote": {
          "anyOf": [
            {
              "$ref": "#/$defs/MajorityVote"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "type": "array"
        },
        "references": {
          "items": {
            "$ref": "#/$defs/Reference"
          },
          "title": "References",
          "type": "array"
        }
      },
      "required": [
        "id",
        "premises",
        "conclusions",
        "analyst_verdicts",
        "model_verdict"
      ],
      "title": "EvaluationItem",
      "type": "object"
    },
    "MajorityVote": {
      "additionalProperties": false,
      "description": "Tally of parsed verdicts plus the resolved majority and tie-break flag.",
      "properties": {
        "good": {
          "default": 0,
          "title": "Good",
          "type": "integer"
        },
        "bad": {
          "default": 0,
          "title": "Bad",
          "type": "integer"
        },
        "abstain": {
          "default": 0,
          "title": "Abstain",
          "type": "integer"
        },
        "verdict": {
          "$ref": "#/$defs/Verdict"
        },
        "tie_broken": {
          "default": false,
          "title": "Tie Broken",
          "type": "boolean"
        }
      },
      "required": [
        "verdict"
      ],
      "title": "MajorityVote",
      "type": "object"
    },
    "ModelInfo": {
      "additionalProperties": false,
      "description": "Identity of the model under evaluation and the decoding params used.",
      "properties": {
        "provider": {
          "title": "Provider",
          "type": "string"
        },
        "model_id": {
          "title": "Model Id",
          "type": "string"
        },
        "params": {
          "$ref": "#/$defs/ProviderParams"
        }
      },
      "required": [
        "provider",
        "model_id"
      ],
      "title": "ModelInfo",
      "type": "object"
    },
    "ProviderParams": {
      "additionalProperties": true,
      "description": "Decoding parameters passed to a provider sample call.\n\nThe ``max_tokens`` default of 1024 is sized for current frontier models\nthat consume budget on silent internal reasoning. See\n:class:`infereval.providers.base.SampleRequest` and\n``docs/providers.md`` for the rationale and per-provider guidance.",
      "properties": {
        "temperature": {
          "default": 1.0,
          "title": "Temperature",
          "type": "number"
        },
        "max_tokens": {
          "default": 1024,
          "title": "Max Tokens",
          "type": "integer"
        },
        "top_p": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Top P"
        },
        "seed": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Seed"
        },
        "stop": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Stop",
          "type": "array"
        }
      },
      "title": "ProviderParams",
      "type": "object"
    },
    "Reference": {
      "additionalProperties": false,
      "description": "A traceable provenance entry for a benchmark, bearer, or item.\n\nThe motivating use case is regulated-domain benchmarks (medical, legal,\nfinancial) where every non-trivial implication needs a citation to a\nguideline, statute, or peer-reviewed source. Recording these as\nstructured objects lets downstream tooling render bibliographies,\nvalidate DOIs, and connect items to the documents that justify them.\n\nOnly :attr:`citation` is required. The other fields populate when the\nrelevant identifier is known and remain ``None`` otherwise.\n\nAuthoring shorthand: a plain string in any ``references`` list is\nauto-promoted to a :class:`Reference` with the string as\n:attr:`citation` and everything else ``None``. See\n:func:`_promote_reference_shorthand`.",
      "properties": {
        "citation": {
          "title": "Citation",
          "type": "string"
        },
        "doi": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Doi"
        },
        "url": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Url"
        },
        "section": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Section"
        },
        "note": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Note"
        }
      },
      "required": [
        "citation"
      ],
      "title": "Reference",
      "type": "object"
    },
    "SampleRecord": {
      "additionalProperties": false,
      "description": "One sampled response from the provider plus its parsed verdict.",
      "properties": {
        "sample_index": {
          "title": "Sample Index",
          "type": "integer"
        },
        "raw_response": {
          "title": "Raw Response",
          "type": "string"
        },
        "parsed_verdict": {
          "$ref": "#/$defs/Verdict"
        },
        "parse_status": {
          "default": "ok",
          "enum": [
            "ok",
            "unparseable",
            "sample_failed",
            "budget_clipped"
          ],
          "title": "Parse Status",
          "type": "string"
        },
        "request_id": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Request Id"
        },
        "wall_time_ms": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Wall Time Ms"
        },
        "usage": {
          "anyOf": [
            {
              "$ref": "#/$defs/SampleUsage"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "finish_reason": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Finish Reason"
        },
        "reasoning_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reasoning Tokens"
        }
      },
      "required": [
        "sample_index",
        "raw_response",
        "parsed_verdict"
      ],
      "title": "SampleRecord",
      "type": "object"
    },
    "SampleUsage": {
      "additionalProperties": true,
      "description": "Token usage for a single provider call (provider-specific keys allowed).",
      "properties": {
        "input_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Tokens"
        },
        "output_tokens": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Tokens"
        }
      },
      "title": "SampleUsage",
      "type": "object"
    },
    "Verdict": {
      "description": "Endorsement verdict :math:`E_M(\\langle \\Gamma, \\Delta \\rangle)`.\n\nString-valued so JSON serialization yields ``\"good\"`` / ``\"bad\"`` / ``\"abstain\"``\ndirectly. The ``(str, Enum)`` pattern is used in place of\n:class:`enum.StrEnum` for Python 3.10 compatibility.",
      "enum": [
        "good",
        "bad",
        "abstain"
      ],
      "title": "Verdict",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "An evaluation :math:`\\eta` of a model against a benchmark.",
  "properties": {
    "schema_version": {
      "const": "1.0",
      "default": "1.0",
      "title": "Schema Version",
      "type": "string"
    },
    "id": {
      "title": "Id",
      "type": "string"
    },
    "benchmark_id": {
      "title": "Benchmark Id",
      "type": "string"
    },
    "benchmark_hash": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Benchmark Hash"
    },
    "model": {
      "$ref": "#/$defs/ModelInfo"
    },
    "endorsement_config": {
      "$ref": "#/$defs/EndorsementConfig"
    },
    "framework_version": {
      "default": "0.3.3",
      "title": "Framework Version",
      "type": "string"
    },
    "started_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "finished_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Finished At"
    },
    "items": {
      "items": {
        "$ref": "#/$defs/EvaluationItem"
      },
      "title": "Items",
      "type": "array"
    },
    "references": {
      "items": {
        "$ref": "#/$defs/Reference"
      },
      "title": "References",
      "type": "array"
    },
    "paraphrase_variant": {
      "default": 0,
      "title": "Paraphrase Variant",
      "type": "integer"
    }
  },
  "required": [
    "id",
    "benchmark_id",
    "model",
    "items"
  ],
  "type": "object"
}
